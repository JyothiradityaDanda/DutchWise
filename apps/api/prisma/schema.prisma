generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  name              String
  avatarUrl         String?
  preferredCurrency String   @default("USD")
  themePreference   String   @default("system")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  groupMemberships GroupMember[]
  paidExpenses     Expense[]          @relation("PaidBy")
  createdExpenses  Expense[]          @relation("CreatedBy")
  participations   ExpenseParticipant[]
  sentSettlements  Settlement[]       @relation("Payer")
  receivedSettlements Settlement[]    @relation("Receiver")
  createdSettlements Settlement[]     @relation("SettlementCreator")
  activities       ActivityEvent[]
  createdGroups    Group[]
}

model Group {
  id          String   @id @default(uuid())
  name        String
  type        String   @default("other")
  icon        String   @default("🎉")
  description String?
  createdBy   String
  creator     User     @relation(fields: [createdBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  activities  ActivityEvent[]
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Expense {
  id              String    @id @default(uuid())
  groupId         String
  title           String
  description     String?
  amount          Float
  currency        String    @default("USD")
  paidByUserId    String
  date            DateTime
  category        String    @default("General")
  splitType       String    @default("equal")
  createdByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  group       Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidByUser  User               @relation("PaidBy", fields: [paidByUserId], references: [id])
  createdByUser User             @relation("CreatedBy", fields: [createdByUserId], references: [id])
  participants ExpenseParticipant[]
}

model ExpenseParticipant {
  id         String @id @default(uuid())
  expenseId  String
  userId     String
  shareType  String @default("equal")
  shareValue Float  @default(1)
  owedAmount Float

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
}

model Settlement {
  id              String   @id @default(uuid())
  groupId         String
  payerUserId     String
  receiverUserId  String
  amount          Float
  currency        String   @default("USD")
  date            DateTime @default(now())
  note            String?
  createdByUserId String
  createdAt       DateTime @default(now())

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer    User  @relation("Payer", fields: [payerUserId], references: [id])
  receiver User  @relation("Receiver", fields: [receiverUserId], references: [id])
  createdByUser User @relation("SettlementCreator", fields: [createdByUserId], references: [id])
}

model ActivityEvent {
  id          String   @id @default(uuid())
  groupId     String?
  actorUserId String
  type        String
  entityType  String
  entityId    String
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())

  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor User   @relation(fields: [actorUserId], references: [id])
}
